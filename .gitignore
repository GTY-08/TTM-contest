app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment variables (NEVER commit secrets)
.env.local
.fcm-secret.env
.env
.env.local
.env.*.local
.env.production
.env.development
mobileok-server/.env.mobileok

# Firebase config files (may contain secrets)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Supabase CLI local link (project ref, pooler URL)
supabase/.temp/

# NexBeSign Java SDK artifacts / secrets
nexbesign-server/vendor/
nexbesign-server/secrets/
*.war

# DreamSecurity Mobile-ok artifacts / secrets
mobileok-server/secrets/*
!mobileok-server/secrets/.gitkeep
mobileok-server/target/
*mok_keyInfo*.zip
